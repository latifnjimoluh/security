CORRIGÉ TP 3 — Script nftables Complet 
SOLUTION COMPLÈTE nftables 
#!/usr/sbin/nft -f 
flush ruleset 
 
define WAN = eth0 
define LAN = eth1 
define DMZ = eth2 
define LAN_NET = 192.168.50.0/24 
define DMZ_WEB = 10.0.5.10 
 
table inet firewall { 
  set brute_force { type ipv4_addr; flags dynamic, timeout; timeout 600s; } 
 
  chain input { 
    type filter hook input priority 0; policy drop; 
    iif lo accept 
    ct state established,related accept 
    ct state invalid drop 
    ip protocol icmp limit rate 2/second accept 
    # SSH depuis LAN uniquement + anti brute force 
    iif $LAN ip saddr $LAN_NET tcp dport 22 ct state new \ 
      add @brute_force { ip saddr ct count over 3 } drop 
    iif $LAN ip saddr $LAN_NET tcp dport 22 ip saddr != @brute_force accept 
  } 
 
  chain forward { 
    type filter hook forward priority 0; policy drop; 
    ct state established,related accept 
    # LAN → Internet 
    iif $LAN oif $WAN ip saddr $LAN_NET accept 
    # LAN → DMZ Web 
    iif $LAN oif $DMZ ip daddr $DMZ_WEB tcp dport { 80, 443 } accept 
    # Internet → DMZ Web 
    iif $WAN oif $DMZ ip daddr $DMZ_WEB tcp dport { 80, 443 } ct state new accept 