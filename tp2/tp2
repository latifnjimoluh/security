#!/bin/bash 
# Pare-feu type entreprise — Linux Gateway 
 
IPT=/sbin/iptables 
LAN_IF=eth1     # Interface LAN interne 
WAN_IF=eth0     # Interface WAN (Internet) 
DMZ_IF=eth2     # Interface DMZ 
LAN_NET=192.168.0.0/16 
DMZ_NET=10.0.1.0/24 
 
# 1. Flush des règles existantes 
$IPT -F && $IPT -X && $IPT -Z 
$IPT -t nat -F && $IPT -t mangle -F 
 
# 2. Politique par défaut : tout bloquer 
$IPT -P INPUT DROP 
$IPT -P FORWARD DROP 
$IPT -P OUTPUT ACCEPT 
 
# 3. Loopback 
$IPT -A INPUT -i lo -j ACCEPT 
$IPT -A OUTPUT -o lo -j ACCEPT 
 
# 4. Trafic établi/relié 
$IPT -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 
$IPT -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 
 
# 5. ICMP limité (anti-flood) 
$IPT -A INPUT -p icmp --icmp-type echo-request -m limit --limit 1/s --limit-burst 5 -j ACCEPT 
 
# 6. SSH depuis réseau admin uniquement 
$IPT -A INPUT -i $LAN_IF -s 192.168.100.0/24 -p tcp --dport 22 -j ACCEPT 
 
# 7. LAN → Internet (NAT) 
$IPT -A FORWARD -i $LAN_IF -o $WAN_IF -m conntrack --ctstate NEW -j ACCEPT 
