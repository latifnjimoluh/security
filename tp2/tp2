CONFIGURATION nftables — Politique Entreprise 
#!/usr/sbin/nft -f 
# /etc/nftables.conf — Politique sécurité entreprise 
 
flush ruleset 
 
table inet firewall { 
 
  # Ensembles réutilisables 
  set admin_ips { type ipv4_addr; elements = { 192.168.100.0/24 } } 
  set blocked_ips { type ipv4_addr; flags dynamic, timeout; timeout 3600s; } 
 
  chain input { 
    type filter hook input priority 0; policy drop; 
 
    iif lo accept 
    ct state established,related accept 
    ct state invalid drop 
 
    # ICMP limité 
    ip protocol icmp icmp type echo-request limit rate 5/second accept 
 
    # SSH uniquement depuis admin 
    ip saddr @admin_ips tcp dport 22 accept 
 
    # Blocklist dynamique 
    ip saddr @blocked_ips drop 
 
    # Log et drop 
    log prefix "[nft-drop] " level warn 
  } 
 
  chain forward { 
    type filter hook forward priority 0; policy drop; 
